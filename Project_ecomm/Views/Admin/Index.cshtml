

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Admin Dashboard</title>

    <link href="~/Content/CssFile/adminPAnel.css" rel="stylesheet" />

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

</head>
<body>
    <div class="container-fluid p-4">

        <!-- Cards -->
        <div class="row g-4">

            <div class="col-md-3">
                <div class="card dashboard-card p-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6>Total Products</h6>
                            <h3>245</h3>
                        </div>
                        <i class="bi bi-box card-icon text-primary"></i>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card dashboard-card p-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6>Total Orders</h6>
                            <h3>120</h3>
                        </div>
                        <i class="bi bi-cart card-icon text-success"></i>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card dashboard-card p-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6>Total Customers</h6>
                            <h3>89</h3>
                        </div>
                        <i class="bi bi-people card-icon text-warning"></i>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card dashboard-card p-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6>Total Revenue</h6>
                            <h3>₹2,45,000</h3>
                        </div>
                        <i class="bi bi-currency-rupee card-icon text-danger"></i>
                    </div>
                </div>
            </div>

        </div>

        <!-- Recent Orders Table -->
        <div class="card mt-5 p-3 dashboard-card">
            <h5 class="mb-3">Recent Orders</h5>
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Order ID</th>
                            <th>Customer</th>
                            <th>Date</th>
                            <th>Amount</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>#1021</td>
                            <td>Priya Sharma</td>
                            <td>12 Feb 2026</td>
                            <td>₹12,000</td>
                            <td><span class="badge bg-success">Completed</span></td>
                        </tr>
                        <tr>
                            <td>#1022</td>
                            <td>Anjali Verma</td>
                            <td>11 Feb 2026</td>
                            <td>₹8,500</td>
                            <td><span class="badge bg-warning">Pending</span></td>
                        </tr>
                        <tr>
                            <td>#1023</td>
                            <td>Ritika Jain</td>
                            <td>10 Feb 2026</td>
                            <td>₹15,700</td>
                            <td><span class="badge bg-danger">Cancelled</span></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
</div>
</body>
</html>
