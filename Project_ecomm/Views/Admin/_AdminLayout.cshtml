<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Admin Dashboard</title>
    <link rel="icon" href="~/Images/icon.png" />
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

    <link href="~/Content/CssFile/adminPAnel.css" rel="stylesheet" />

</head>
<body>
    <div class="container-fluid pt-3 px-4">

        <div class="row">

            <!-- Sidebar -->
            <div class="col-md-2 sidebar p-0">
                <h4 class="text-center py-4 border-bottom">💖 Admin</h4>

                <a href="@Url.Action("Index", "Admin")" class="active"><i class="bi bi-speedometer2"></i> Dashboard</a>
             
                <a href="@Url.Action("AddProducts", "Admin")">
                    <i class="bi bi-plus-circle"></i> Add Product
                </a>

                <a href="@Url.Action("ProductList", "Admin")">
                    <i class="bi bi-box"></i> View Products
                </a>

                <a href="#"><i class="bi bi-tags"></i> Categories</a>
                <a href="#"><i class="bi bi-cart"></i> Orders</a>
                <a href="#"><i class="bi bi-people"></i> Customers</a>
                <a href="#"><i class="bi bi-graph-up"></i> Reports</a>
                <a href="#"><i class="bi bi-gear"></i> Settings</a>
                <a href="#"><i class="bi bi-box-arrow-right"></i> Logout</a>
            </div>

            <!-- Main Content -->
            <div class="col-md-10">

                <!-- Navbar -->
                <nav class="navbar px-4 py-3 border-bottom">
                    <div class="d-flex justify-content-between w-100">
                        <h5 class="mb-0">Dashboard Overview</h5>
                        <div>
                            <span class="me-3">Welcome, Admin</span>
                            <i class="bi bi-person-circle fs-4"></i>
                        </div>
                    </div>
                </nav>

                <div class="p-4">
                    @RenderBody()
                </div>

            </div>

        </div>

    </div>
</body>
</html>
