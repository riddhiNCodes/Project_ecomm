@using Microsoft.AspNet.Identity
@{
    Layout = null;
    var count = 0;
    if (Session["Cart"] != null)
    {
        var cart = (List<Project_ecomm.Models.CartItem>)Session["Cart"];
        count = cart.Count;
    }
}


<!DOCTYPE html>
<html>
<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Shaadi Shringar</title>

    <link rel="icon" href="~/Images/icon.png" />


    <link href="~/Content/bootstrap.min.css" rel="stylesheet" />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Lavishly+Yours&family=Tangerine:wght@400;700&display=swap" rel="stylesheet">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <link href="~/Content/CssFile/nav.css" rel="stylesheet" />



    @*@Styles.Render("~/Content/css")*@
    @Scripts.Render("~/bundles/modernizr")

</head>
<body>

    <div class="content">
        <nav class="navbar navbar-expand-lg ">
            <div class="container-fluid">
                <div class="col-md-6 col-sm-6">
                    <div class="logo justify-content-center">
                        <img src="~/Images/logo_asp.png" alt="logo" />
                        <span class="text-center">Jewels of culture, Crowned in Love</span>
                    </div>
                </div>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>



                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto align-items-lg-center">

                        <li class="nav-item">
                            <a class="nav-link" href="/Home/Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Products/Index">Bridal Collection</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Home/About">About Us</a>
                        </li>

                        @*<li class="nav-item">
                                <a class="nav-link btn btn-warning text-dark px-3 ms-lg-3"
                                   style="border-radius: 20px;font-size:17px;"
                                   href="/Account/Login">
                                    Signing In
                                </a>
                            </li>*@

                    <ul class="navbar-nav ms-auto align-items-center">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <span class="nav-link fw-semibold text-warning ">
                                <i class="bi bi-person-circle"></i> Hello, @User.Identity.Name
                            </span>

                            @*<li class="nav-item me-2 text-warning fw-bold ">
                                Hello, <strong>@User.Identity.GetUserName()</strong>
                            </li>*@

                            <li class="nav-item">
                                @using (Html.BeginForm("LogOff", "Account", FormMethod.Post))
                                {
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-link nav-link text-danger">
                                        Logout
                                    </button>
                                }
                            </li>

                            <li>
                                <a href="@Url.Action("MyOrders","Order")" class="text-light">My Profile</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="@Url.Action("Login", "Account")">Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="@Url.Action("Register", "Account")">Register</a>
                            </li>
                        }

                    </ul>

                    </ul>
                    
                </div>
            </div>
        </nav>

        <div class="container-fluid">
            <div class="p-3 subhead">
                <div class="row align-items-center">

                    <!-- BRAND NAME (takes maximum space) -->
                    <div class="col">
                        <span class="name">
                            Shaadi Shringar
                        </span>
                    </div>

                    <!-- SEARCH -->
                    <div class="col-auto">
                        <div class="search-box p-2">
                            <input type="search" placeholder="Search">
                            <i class="fa-solid fa-magnifying-glass search-icon"></i>
                        </div>
                    </div>

                    <!-- STATES DROPDOWN -->
                    <div class="col-auto">
                        <div class="btn-group shaadi-dropdown">
                            <button type="button" class="btn btn-state">Shop by State</button>
                            <button type="button"
                                    class="btn btn-state dropdown-toggle dropdown-toggle-split"
                                    data-bs-toggle="dropdown">
                                <span class="visually-hidden">Toggle Dropdown</span>
                            </button>

                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" href="@Url.Action("State","Products", new { state="Maharashtra" })">Maharashtra</a></li>
                                <li><a class="dropdown-item" href="#">Rajasthan</a></li>
                                <li><a class="dropdown-item" href="#">Gujarat</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" href="#">All States</a></li>
                            </ul>
                        </div>
                    </div>

                    <!-- CART -->
                    <div class="col-auto">
                        <button class="cart-btn">
                            <i class="bi bi-bag-heart"></i>

                            <a class="nav-link" href="@Url.Action("Cart","Products")">
                                Cart ( @count )
                            </a>
                        </button>

                    </div>
                    @*<ul class="nav">
                            <li class="nav-item">
                                <a class="nav-link" href="@Url.Action("Cart","Products")">
                                    Cart (@count)
                                </a>
                            </li>
                        </ul>*@



                    <!-- WISHLIST -->
                    <div class="col-auto">
                        <i class="fa-solid fa-heart "
                           style="color:#ed5566;font-size:30px; "></i>
                    </div>

                </div>
            </div>
        </div>






        @RenderBody()
        <hr />
        <footer>
            <p>&copy; @DateTime.Now.Year - My ASP.NET Application</p>
        </footer>
    </div>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", required: false)
</body>

</html>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>

