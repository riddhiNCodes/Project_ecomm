@model Project_ecomm.Models.Product

@{
    ViewBag.Title = "Product Details";
}

<style>
    .price-text {
        color: #b76e79;
        font-size: 24px;
        font-weight: 600;
    }

    .btn-luxury {
        background-color: #b76e79;
        color: white;
        border: none;
    }

        .btn-luxury:hover {
            background-color: #9c4f5c;
            color: white;
        }
</style>

<div class="container mt-5">

    <div class="row shadow-lg p-4 rounded-4 bg-white">

        <!-- Image -->
        <div class="col-md-6 text-center">
            <img src="@Url.Content(Model.ImageUrl)"
                 class="img-fluid rounded-4"
                 style="max-height:450px; object-fit:cover;" />
        </div>

        <!-- Details -->
        <div class="col-md-6">

            <h2>@Model.Name</h2>

            <p class="text-muted">@Model.Category</p>

            <p class="price-text">
                ₹ @Model.Price
            </p>

            <p class="mt-3">
                @Model.Description
            </p>

            <a href="@Url.Action("AddToCart","Products", new { id = Model.ProductId })"
               class="btn btn-luxury mt-4 w-50">
                Add to Cart
            </a>

        </div>
    </div>
</div>

