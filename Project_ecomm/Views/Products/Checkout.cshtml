@model List<Project_ecomm.Models.CartItem>

@{
    decimal grandTotal = Model.Sum(x => x.Product.Price * x.Quantity);
}
<link href="~/Content/CssFile/cart.css" rel="stylesheet" />


<div class="container mt-5">

    <h2 class="mb-4">Checkout</h2>

    <h4>Total Amount: ₹ @grandTotal</h4>

    <hr />

    <form method="post" action="#">
        <div class="mb-3">
            <label>Name</label>
            <input type="text" class="form-control" required />
        </div>

        <div class="mb-3">
            <label>Address</label>
            <textarea class="form-control" required></textarea>
        </div>

        <div class="mb-3">
            <label>Mobile</label>
            <input type="text" class="form-control" required />
        </div>

        <button type="submit" class="btn btn-success">
            Place Order
        </button>
    </form>
</div>