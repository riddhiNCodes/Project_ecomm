@{
    ViewBag.Title = "Secure Payment";
}

<script src="https://checkout.razorpay.com/v1/checkout.js"></script>

<style>

    .payment-wrapper {
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg,#fdf7f8,#f3e8eb);
    }

    .payment-card {
        background: white;
        padding: 50px;
        border-radius: 20px;
        text-align: center;
        max-width: 500px;
        width: 100%;
        box-shadow: 0 15px 40px rgba(183,110,121,0.25);
        border: 1px solid #f1d4d9;
    }

    .payment-title {
        font-size: 28px;
        font-weight: 600;
        color: #b76e79;
        margin-bottom: 15px;
    }

    .payment-text {
        color: #666;
        margin-bottom: 25px;
    }

    .amount-box {
        background: #fdf7f8;
        padding: 20px;
        border-radius: 12px;
        margin-bottom: 30px;
        font-size: 22px;
        font-weight: 600;
        color: #7a1f2b;
        border: 1px solid #f1d4d9;
    }

    .pay-btn {
        background-color: #b76e79;
        color: white;
        padding: 14px 35px;
        border: none;
        border-radius: 30px;
        font-size: 16px;
        font-weight: 500;
        transition: 0.3s ease;
    }

        .pay-btn:hover {
            background-color: #9e5c67;
        }

    .secure-text {
        margin-top: 20px;
        color: #888;
        font-size: 14px;
    }
</style>


<div class="payment-wrapper">

    <div class="payment-card">

        <div class="payment-title">
            Secure Payment
        </div>

        <div class="payment-text">
            Complete your payment to confirm your order.
        </div>

        <div class="amount-box">
            Total Amount: ₹ @ViewBag.Amount
        </div>

        <button id="rzp-button" class="pay-btn">
            Pay Securely
        </button>

        <div class="secure-text">
            🔒 Payments are secured by Razorpay
        </div>

    </div>

</div>


<script>

var options = {
    "key": "@ViewBag.Key",
    "amount": "@ViewBag.DisplayAmount",
    "currency": "INR",
    "name": "Shaadi Shringar",
    "description": "Order Payment",
    "order_id": "@ViewBag.OrderId",
    @*@ViewBag.Method*@

    handler: function (response) {

        window.location.href = "/Order/PaymentSuccess";

    },

    "prefill": {
        "name": "",
        "email": "",
        "contact": ""
    },

    "theme": {
        "color": "#b76e79"
    }

};

var rzp1 = new Razorpay(options);

document.getElementById('rzp-button').onclick = function(e){
    rzp1.open();
    e.preventDefault();
}

</script>
